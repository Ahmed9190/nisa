---
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
import products from '../data/products.json';

export interface Props {
	title?: string;
	description?: string;
}

const { 
    title = site.title, 
    description = site.description 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <Seo title={title} description={description} />
    <style is:global>
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #FFF5E0;
            color: #204566;
        }
    </style>
</head>
<body class="antialiased">
    <Header />
    <main>
        <slot />
    </main>
    <Footer />

    <!-- Cart Drawer -->
    <div id="cart-drawer-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-40 hidden"></div>
    <div id="cart-drawer" class="fixed top-0 right-0 h-full w-full max-w-md bg-[#FFF5E0] shadow-2xl z-50 transform translate-x-full">
        <div class="flex flex-col h-full">
            <div class="flex items-center justify-between p-6 border-b border-[#D4E4E8]">
                <h2 class="text-2xl font-medium">Your Cart</h2>
                <button id="close-cart-button" class="text-3xl">&times;</button>
            </div>
            <div id="cart-items" class="flex-grow p-6 overflow-y-auto">
                <!-- Cart items will be injected here -->
                <p class="text-center text-[#6B7B8C]">Your cart is empty.</p>
            </div>
            <div class="p-6 border-t border-[#D4E4E8]">
                <div class="flex justify-between items-center text-xl font-medium mb-4">
                    <span>Subtotal</span>
                    <span id="cart-subtotal">EGP 0</span>
                </div>
                <a href="/checkout" id="proceed-to-checkout" class="btn-primary w-full text-center">Proceed to Checkout</a>
            </div>
        </div>
    </div>

    <!-- Size Guide Modal -->
    <div id="size-guide-modal-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden"></div>
    <div id="size-guide-modal" class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[#FFF5E0] shadow-2xl z-50 rounded-lg p-8 w-11/12 max-w-2xl hidden">
         <button id="close-size-guide-button" class="absolute top-4 right-4 text-3xl">&times;</button>
         <h2 class="text-2xl font-medium mb-4 text-center">Size Guide</h2>
         <p class="text-center text-[#6B7B8C] mb-6">All measurements are in centimeters (cm).</p>
         <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-[#D4E4E8]">
                        <th class="py-2 px-4">Size</th>
                        <th class="py-2 px-4">Bust</th>
                        <th class="py-2 px-4">Waist</th>
                        <th class="py-2 px-4">Hips</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="border-b border-[#D4E4E8]">
                        <td class="py-2 px-4 font-medium">S</td>
                        <td class="py-2 px-4">86-89</td>
                        <td class="py-2 px-4">69-71</td>
                        <td class="py-2 px-4">94-97</td>
                    </tr>
                    <tr class="border-b border-[#D4E4E8]">
                        <td class="py-2 px-4 font-medium">M</td>
                        <td class="py-2 px-4">91-94</td>
                        <td class="py-2 px-4">74-76</td>
                        <td class="py-2 px-4">99-102</td>
                    </tr>
                     <tr class="border-b border-[#D4E4E8]">
                        <td class="py-2 px-4 font-medium">L</td>
                        <td class="py-2 px-4">98-102</td>
                        <td class="py-2 px-4">80-84</td>
                        <td class="py-2 px-4">105-109</td>
                    </tr>
                     <tr>
                        <td class="py-2 px-4 font-medium">XL</td>
                        <td class="py-2 px-4">105-109</td>
                        <td class="py-2 px-4">88-92</td>
                        <td class="py-2 px-4">113-117</td>
                    </tr>
                </tbody>
            </table>
         </div>
    </div>

    <script define:vars={{ products: products.products }}>
        // This script is inlined and has access to the `products` variable
    </script>
    <script is:inline>
let products = window.products;

// --- UTILS ---
const formatPrice = (price, currency = 'EGP') => {
    return new Intl.NumberFormat('en-US', {
        style: 'currency', currency, minimumFractionDigits: 0
    }).format(price);
};

// --- SHOPPING CART ---
class ShoppingCart {
    constructor() { this.items = JSON.parse(localStorage.getItem('nisaCart')) || []; }
    addItem(product, color, size, quantity = 1) {
        const existingItem = this.items.find(i => i.id === product.id && i.size === size && i.color.name === color.name);
        if (existingItem) { existingItem.quantity += quantity; }
        else {
            this.items.push({ id: product.id, name: product.name, price: product.price, size, color, quantity, image: color.images[0] });
        }
        this.save();
    }
    removeItem(itemId, colorName, size) {
        this.items = this.items.filter(i => !(i.id === itemId && i.color.name === colorName && i.size === size));
        this.save();
    }
    updateQuantity(itemId, colorName, size, newQuantity) {
        const item = this.items.find(i => i.id === itemId && i.color.name === colorName && i.size === size);
        if (item) {
            if (newQuantity > 0) {
                item.quantity = newQuantity;
            } else {
                this.removeItem(itemId, colorName, size);
            }
        }
        this.save();
    }
    getTotal() { return this.items.reduce((sum, item) => sum + (item.price * item.quantity), 0); }
    getItemCount() { return this.items.reduce((sum, item) => sum + item.quantity, 0); }
    save() { localStorage.setItem('nisaCart', JSON.stringify(this.items)); }
}

const cart = new ShoppingCart();

function updateCartUI() {
    const count = cart.getItemCount();
    const countElements = document.querySelectorAll('.cart-count');
    countElements.forEach(el => {
        el.textContent = count;
        el.style.display = count > 0 ? 'flex' : 'none';
    });

    const itemsContainer = document.getElementById('cart-items');
    if (itemsContainer && cart.items.length === 0) {
        itemsContainer.innerHTML = `<p class="text-center text-[#6B7B8C]">Your cart is empty.</p>`;
    } else if (itemsContainer) {
        itemsContainer.innerHTML = cart.items.map(item => `
            <div class="flex gap-4 mb-4">
                <img src="${item.image}" alt="${item.name}" class="w-24 h-32 object-cover rounded-md">
                <div class="flex-grow flex flex-col justify-between">
                    <div>
                        <h4 class="font-medium">${item.name}</h4>
                        <p class="text-sm text-[#6B7B8C]">${item.color.name} / ${item.size}</p>
                        <p class="font-medium mt-2">${formatPrice(item.price)}</p>
                    </div>
                    <div class="flex items-center border border-gray-300 rounded w-max mt-2">
                         <button class="px-2 py-1 cart-quantity-change" data-id="${item.id}" data-color="${item.color.name}" data-size="${item.size}" data-amount="-1">-</button>
                         <span class="px-3 py-1">${item.quantity}</span>
                         <button class="px-2 py-1 cart-quantity-change" data-id="${item.id}" data-color="${item.color.name}" data-size="${item.size}" data-amount="1">+</button>
                    </div>
                </div>
                 <button class="text-xs text-red-500 hover:underline remove-from-cart self-start" data-id="${item.id}" data-color="${item.color.name}" data-size="${item.size}">Remove</button>
            </div>
        `).join('');
    }

    const cartSubtotal = document.getElementById('cart-subtotal');
    if(cartSubtotal) {
        cartSubtotal.textContent = formatPrice(cart.getTotal());
    }
}

function toggleCartDrawer(open) {
    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-drawer-overlay');
    if (drawer && overlay) {
        if (open) {
            overlay.classList.remove('hidden');
            drawer.classList.remove('translate-x-full');
        } else {
            overlay.classList.add('hidden');
            drawer.classList.add('translate-x-full');
        }
    }
}

function renderCheckoutPage() {
    const itemsContainer = document.getElementById('checkout-items');
    const subtotalEl = document.getElementById('checkout-subtotal');
    const shippingEl = document.getElementById('checkout-shipping');
    const totalEl = document.getElementById('checkout-total');

    if (!itemsContainer) return;

    const shippingCost = cart.items.length > 0 ? 50 : 0;

    if (cart.items.length === 0) {
        itemsContainer.innerHTML = `<p class="text-center text-[#6B7B8C]">Your cart is empty.</p>`;
        const checkoutButton = document.querySelector('#checkout-form button[type="submit"]');
        if(checkoutButton) {
            checkoutButton.disabled = true;
        }
    } else {
        itemsContainer.innerHTML = cart.items.map(item => `
            <div class="flex gap-4 items-center">
                <div class="relative">
                    <img src="${item.image}" alt="${item.name}" class="w-16 h-20 object-cover rounded-md">
                    <span class="absolute -top-2 -right-2 bg-[#BEE2E8] text-[#204566] text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center">${item.quantity}</span>
                </div>
                <div class="flex-grow">
                    <h4 class="font-medium text-sm">${item.name}</h4>
                    <p class="text-xs text-[#6B7B8C]">${item.color.name} / ${item.size}</p>
                </div>
                <span class="text-sm font-medium">${formatPrice(item.price * item.quantity)}</span>
            </div>
        `).join('');
    }

    const subtotal = cart.getTotal();
    const total = subtotal + shippingCost;
    if(subtotalEl) subtotalEl.textContent = formatPrice(subtotal);
    if(shippingEl) shippingEl.textContent = formatPrice(shippingCost);
    if(totalEl) totalEl.textContent = formatPrice(total);

    // Populate hidden fields for Formspree
    const orderSummaryInput = document.getElementById('order-summary-input');
    const orderTotalInput = document.getElementById('order-total-input');

    if(orderSummaryInput && orderTotalInput) {
        const summaryText = cart.items.map(item =>
            `${item.name} (${item.color.name} / ${item.size}) - Qty: ${item.quantity} - Price: ${formatPrice(item.price * item.quantity)}`
        ).join('\n');

        orderSummaryInput.value = summaryText;
        orderTotalInput.value = formatPrice(total);
    }
}

document.addEventListener('DOMContentLoaded', () => {
    updateCartUI();
    renderCheckoutPage();

    const cartButton = document.getElementById('cart-button');
    if(cartButton) {
        cartButton.addEventListener('click', () => toggleCartDrawer(true));
    }
    const closeCartButton = document.getElementById('close-cart-button');
    if(closeCartButton) {
        closeCartButton.addEventListener('click', () => toggleCartDrawer(false));
    }
    const cartDrawerOverlay = document.getElementById('cart-drawer-overlay');
    if(cartDrawerOverlay) {
        cartDrawerOverlay.addEventListener('click', () => toggleCartDrawer(false));
    }

    document.body.addEventListener('click', e => {
        const addToCartButton = e.target.closest('.add-to-cart-card-btn');
        if (addToCartButton) {
            e.preventDefault();
            const productId = addToCartButton.dataset.productId;
            const product = products.find(p => p.id === productId);
            if (product && product.inStock) {
                const defaultColor = product.colors[0];
                const defaultSize = product.sizes[0];
                cart.addItem(product, defaultColor, defaultSize);
                updateCartUI();
                toggleCartDrawer(true);
            }
        }

        const removeFromCartButton = e.target.closest('.remove-from-cart');
        if(removeFromCartButton) {
            const { id, color, size } = removeFromCartButton.dataset;
            cart.removeItem(id, color, size);
            updateCartUI();
        }

        const quantityChangeButton = e.target.closest('.cart-quantity-change');
        if(quantityChangeButton) {
            const { id, color, size, amount } = quantityChangeButton.dataset;
            const item = cart.items.find(i => i.id === id && i.color.name === color && i.size === size);
            if (item) {
                const newQuantity = item.quantity + parseInt(amount);
                cart.updateQuantity(id, color, size, newQuantity);
                updateCartUI();
            }
        }
    });
});
        // Add mobile menu toggle logic
        const mobileMenuButton = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        if (mobileMenuButton && mobileMenu) {
            mobileMenuButton.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
            });
        }
    </script>
</body>
</html>
