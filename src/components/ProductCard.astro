---
import type { Product } from '../types';

export interface Props {
    product: Product;
}

const { product } = Astro.props;

const formatPrice = (price: number, currency = 'EGP') => {
    return new Intl.NumberFormat('en-US', {
        style: 'currency', currency, minimumFractionDigits: 0
    }).format(price);
};
---

<div class="product-card p-4 flex flex-col text-center border border-[#D4E4E8] rounded-lg shadow-sm hover:shadow-lg transition-shadow duration-300">
    {product.comingSoon && <div class="absolute top-2 left-2 bg-blue-500 text-white text-xs font-bold px-2 py-1 rounded-full">Coming Soon</div>}
    { !product.inStock && !product.comingSoon && <div class="absolute top-2 left-2 bg-gray-500 text-white text-xs font-bold px-2 py-1 rounded-full">Sold Out</div> }
    <a href={!product.comingSoon ? `/product/${product.id}` : '#'} class={product.comingSoon ? 'pointer-events-none' : ''}>
        <img src={product.colors[0].images[0]} alt={product.name} class="w-full h-auto object-cover rounded-md aspect-[3/4]">
    </a>
            <div class="flex-grow flex flex-col pt-4">
                <h3 class="text-xl font-medium">{product.name}</h3>
                <div class="text-lg text-[#6B7B8C] mt-1 flex-grow">
                    {product.price > 0 ? (
                        product.price < product.priceBefore ? (
                            <div class="flex justify-center items-center gap-2">
                                <span class="text-red-500">{formatPrice(product.price)}</span>
                                <span class="line-through text-sm">{formatPrice(product.priceBefore)}</span>
                            </div>
                        ) : (
                            <span>{formatPrice(product.price)}</span>
                        )
                    ) : (
                        <span class="text-lg font-medium">Coming Soon</span>
                    )}
                </div>
                <div class="mt-4 grid grid-cols-2 gap-2">
                    <a href={!product.comingSoon ? `/product/${product.id}` : '#'} class:list={["btn-secondary py-2 px-4 text-sm", { "opacity-50 cursor-not-allowed": product.comingSoon }]}>Details</a>
                    <button class="btn-primary py-2 px-4 text-sm add-to-cart-card-btn" data-product-id={product.id} disabled={!product.inStock || product.comingSoon}>
                        {product.inStock ? 'Add to Cart' : (product.comingSoon ? 'Coming Soon' : 'Sold Out')}
                    </button>
                </div>
    </div>
</div>
    </div>
</div>

<style>
.btn-primary {
    background-color: #204566;
    color: #fffaf0;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    letter-spacing: 0.5px;
}

.btn-primary:hover:not(:disabled) {
    background-color: #163554;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(32, 69, 102, 0.3);
}
.btn-primary:disabled {
    background-color: #6B7B8C;
    cursor: not-allowed;
}

.btn-secondary {
    background-color: transparent;
    color: #204566;
    border: 2px solid #204566;
    padding: calc(0.5rem - 2px) calc(1rem - 2px);
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
}

.btn-secondary:hover {
    background-color: #204566;
    color: #fffaf0;
}
</style>
