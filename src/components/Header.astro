---
import site from "../data/site.json";
---

<header
  class="bg-[#fffaf0]/80 backdrop-blur-lg sticky top-0 z-40 border-b border-[#D4E4E8]"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <a
        href="/"
        class="flex items-center space-x-2 text-4xl font-medium tracking-wider"
      >
        <img
          src="/assets/logo/asset-2-8-68f93a3e091c5.webp"
          alt="nisa logo"
          class="h-12"
        />
      </a>

      <nav class="hidden md:flex items-center space-x-10">
        {
          site.navigation.map(item => (
            <a
              href={item.href}
              class="text-lg hover:text-[#6B7B8C] transition-colors"
            >
              {item.name}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center space-x-4">
        <div class="grid grid-cols-1 sm:grid-cols-1 gap-4">
          <select
            name="currency"
            id="currency-select"
            class="form-input sm:col-span-2 bg-inherit"
            required
          >
            <option data-currency="EGP" value="EGP" selected>EGP</option>
            <option data-currency="SAR" value="SAR">SAR</option>
          </select>
        </div>

        <button id="cart-button" class="relative">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"
            ></path><line x1="3" y1="6" x2="21" y2="6"></line><path
              d="M16 10a4 4 0 0 1-8 0"></path></svg
          >
          <span
            id="cart-count"
            class="absolute -top-2 -right-2 bg-[#BEE2E8] text-[#204566] text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center cart-count"
            style="display: none;">0</span
          >
        </button>
        <button id="mobile-menu-button" class="ml-4 md:hidden">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="3" y1="12" x2="21" y2="12"></line><line
              x1="3"
              y1="6"
              x2="21"
              y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
          >
        </button>
      </div>
    </div>
  </div>
  <div id="mobile-menu" class="hidden md:hidden px-4 pb-4 space-y-2">
    {
      site.navigation.map(item => (
        <a
          href={item.href}
          class="block text-lg hover:text-[#6B7B8C] transition-colors"
        >
          {item.name}
        </a>
      ))
    }
  </div>
</header>
