---
import Layout from '../../layouts/Layout.astro';
import products from '../../data/products.json';
import type { Product } from '../../types';

export async function getStaticPaths() {
  return products.products.map(product => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };

const formatPrice = (price: number, currency = 'EGP') => {
    return new Intl.NumberFormat('en-US', {
        style: 'currency', currency, minimumFractionDigits: 0
    }).format(price);
};
---

<Layout title={product.name + ' - nisa'}>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
         <div class="flex flex-col lg:flex-row gap-12">
            <div class="w-full lg:w-1/2">
                <div class="relative">
                    <img id="main-product-image" src={product.colors[0].images[0]} alt={product.name} class="w-full rounded-lg shadow-lg sticky top-24">
                    <div id="gallery-controls" class="absolute inset-0 flex items-center justify-between px-4 text-white" style="display: none;">
                        <button id="prev-image" class="bg-black/30 rounded-full p-2 hover:bg-black/50 transition-colors">&lt;</button>
                        <button id="next-image" class="bg-black/30 rounded-full p-2 hover:bg-black/50 transition-colors">&gt;</button>
                    </div>
                </div>
                <div id="thumbnail-container" class="flex gap-2 mt-4 overflow-x-auto">
                    <!-- Thumbnails will be injected here -->
                </div>
            </div>
            <div class="w-full lg:w-1/2">
                <h1 class="text-4xl font-medium">{product.name}</h1>
                <div class="text-2xl my-4">
                    {product.discountPrice ? (
                        <div class="flex items-center gap-2">
                            <span class="text-red-500">{formatPrice(product.discountPrice)}</span>
                            <span class="line-through text-base">{formatPrice(product.price)}</span>
                        </div>
                    ) : (
                        <span>{formatPrice(product.price)}</span>
                    )}
                </div>
                <p class="text-[#6B7B8C] leading-relaxed mb-6">{product.description}</p>

                <div class="mb-6">
                    <label class="block font-medium mb-2">Color</label>
                    <div class="flex gap-2">
                        {product.colors.map((color, index) => (
                            <button class=`color-swatch border-2 rounded-full h-8 w-8 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#204566] ${index === 0 ? 'border-[#204566]' : 'border-transparent'}` style={`--swatch-color: ${color.code};`} data-images={JSON.stringify(color.images)} data-color-index={index}></button>
                        ))}
                    </div>
                </div>

                <div class="mb-6">
                     <div class="flex justify-between items-center mb-2">
                        <label class="block font-medium">Size</label>
                        <button id="size-guide-btn" class="text-sm text-[#6B7B8C] underline hover:text-[#204566]">Size Guide</button>
                    </div>
                    <div class="flex gap-2">
                        {product.sizes.map((size, index) => (
                            <button class=`size-btn border-2 px-4 py-2 rounded-md ${index === 0 ? 'bg-[#204566] text-white' : 'bg-transparent'}`>{size}</button>
                        ))}
                    </div>
                </div>

                <button id="add-to-cart-product-page-btn" data-product-id={product.id} class="btn-primary w-full" disabled={!product.inStock}>
                    {product.inStock ? 'Add to Cart' : 'Sold Out'}
                </button>
                {!product.inStock && <p class="text-center mt-4 text-red-600 font-semibold">This product is currently sold out.</p>}

                 <div class="mt-8 flex justify-around text-center text-sm text-[#6B7B8C] border-t border-b border-[#D4E4E8] py-4">
                    <div class="flex items-center gap-2"><span>✓</span><span>Hassle-Free Returns</span></div>
                    <div class="flex items-center gap-2"><span>✓</span><span>Secure Payments</span></div>
                     <div class="flex items-center gap-2"><span>✓</span><span>Quality Fabrics</span></div>
                </div>

                <div class="mt-8">
                    <h3 class="text-xl font-medium mb-4 border-b border-[#D4E4E8] pb-2">Details & Fit</h3>
                    <ul class="text-[#6B7B8C] space-y-2">
                        <li><strong>Fabric:</strong> {product.details.fabric}</li>
                        <li><strong>Fit:</strong> {product.details.fit}</li>
                        <li><strong>Care:</strong> {product.details.care}</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
.color-swatch {
    background-color: var(--swatch-color);
}

.btn-primary {
    background-color: #204566;
    color: #FFF5E0;
    padding: 1rem 2rem;
    border-radius: 6px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    letter-spacing: 0.5px;
}

.btn-primary:hover:not(:disabled) {
    background-color: #163554;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(32, 69, 102, 0.3);
}

.btn-primary:disabled {
    background-color: #6B7B8C;
    cursor: not-allowed;
}
</style>
