---
// src/pages/checkout-complete.astro
import Layout from "../layouts/Layout.astro";
---

<Layout title="Payment Complete - nisa">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-md mx-auto text-center">
      <h1 class="text-4xl font-medium mb-4">Processing Payment</h1>
      <p class="text-[#6B7B8C] mb-8">
        Please wait while we confirm your payment...
      </p>

      <div id="payment-status" class="mb-4">
        <div
          class="animate-spin inline-block w-8 h-8 border-4 border-[#D4E4E8] border-t-[#204566] rounded-full"
        >
        </div>
      </div>

      <p id="status-message" class="text-sm text-[#6B7B8C]"></p>
    </div>
  </div>
</Layout>

<style>
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .animate-spin {
    animation: spin 1s linear infinite;
  }
</style>

<script type="module" is:inline>
  document.addEventListener("DOMContentLoaded", async () => {
    const statusDiv = document.getElementById("payment-status");
    const messageDiv = document.getElementById("status-message");

    try {
      const params = new URLSearchParams(window.location.search);
      const chargeId = params.get("tap_id"); // Tap uses 'tap_id' as the query param

      console.log("Charge ID from URL:", chargeId);

      if (!chargeId) {
        throw new Error("No charge ID found in URL");
      }

      messageDiv.textContent = "Verifying payment...";

      const verifyResponse = await fetch(
        `http://localhost:3000/api/verify-payment?chargeId=${chargeId}`
      );

      if (!verifyResponse.ok) {
        throw new Error(`Verification failed: ${verifyResponse.status}`);
      }

      const verifyData = await verifyResponse.json();
      console.log("Payment verification response:", verifyData);

      if (!verifyData.success) {
        throw new Error("Payment verification failed");
      }

      const paymentStatus = verifyData.data?.status;
      console.log("Payment status:", paymentStatus);

      if (paymentStatus !== "CAPTURED") {
        throw new Error(`Payment not completed. Status: ${paymentStatus}`);
      }

      messageDiv.textContent = "Payment confirmed! Finalizing order...";

      const orderDataStr = localStorage.getItem("orderData");
      if (!orderDataStr) {
        throw new Error("Order data not found");
      }

      const orderData = JSON.parse(orderDataStr);

      const formspreeData = {
        email: orderData.email,
        fullName: orderData.fullName,
        phoneNumber: orderData.phoneNumber,
        streetAddress: orderData.streetAddress,
        apartment: orderData.apartment,
        city: orderData.city,
        governorate: orderData.governorate,
        deliveryInstructions: orderData.deliveryInstructions,
        chargeId: chargeId,
        paymentStatus: paymentStatus,
        amount: verifyData.data?.amount,
        currency: verifyData.data?.currency,
        timestamp: new Date().toISOString(),
      };

      const formspreeResponse = await fetch("https://formspree.io/f/mwprdnqb", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify(formspreeData),
      });

      if (!formspreeResponse.ok) {
        console.warn(
          "Formspree submission had an issue, but payment was successful"
        );
      }

      localStorage.removeItem("orderData");

      localStorage.removeItem("nisaCart");

      document.dispatchEvent(new CustomEvent("cart-updated"));

      messageDiv.textContent = "Payment successful! Redirecting...";

      setTimeout(() => {
        window.location.href = "/?order=success";
      }, 2000);
    } catch (error) {
      console.error("Payment completion error:", error);

      statusDiv.innerHTML = "❌";
      messageDiv.textContent = `Error: ${
        error.message
      }. Please contact support.`;
      const retryBtn = document.createElement("button");
      retryBtn.textContent = "Retry";
      retryBtn.className = "btn-primary mt-4";
      retryBtn.onclick = () => window.location.reload();

      messageDiv.parentElement?.appendChild(retryBtn);
    }
  });
</script>
